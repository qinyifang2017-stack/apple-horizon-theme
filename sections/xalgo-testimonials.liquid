{% comment %}
  xalgo Testimonials — 自媒体评论展示
  支持无限条评论，每条包含：头像、平台、星级、内容、用户名、日期
{% endcomment %}

<section
  id="xalgo-testimonials-{{ section.id }}"
  class="xalgo-testimonials color-{{ section.settings.color_scheme }}"
  style="
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  "
>
  <div class="page-width">
    {%- if section.settings.heading != blank -%}
      <div class="xalgo-testimonials__header">
        <h2 class="xalgo-testimonials__heading">{{ section.settings.heading }}</h2>
        {%- if section.settings.subheading != blank -%}
          <p class="xalgo-testimonials__subheading">{{ section.settings.subheading }}</p>
        {%- endif -%}
      </div>
    {%- endif -%}

    <div class="xalgo-testimonials__grid xalgo-testimonials__grid--{{ section.settings.layout }}">
      {%- for block in section.blocks -%}
        {%- if block.type == 'testimonial' -%}
          <div class="xalgo-testimonial" {{ block.shopify_attributes }}>
            <div class="xalgo-testimonial__header">
              {%- if block.settings.avatar != blank -%}
                <div class="xalgo-testimonial__avatar">
                  {{
                    block.settings.avatar
                    | image_url: width: 120
                    | image_tag:
                      class: 'xalgo-testimonial__avatar-img',
                      widths: '60, 80, 120',
                      sizes: '60px',
                      alt: block.settings.author_name
                  }}
                </div>
              {%- else -%}
                <div class="xalgo-testimonial__avatar xalgo-testimonial__avatar--placeholder">
                  <svg viewBox="0 0 24 24" fill="currentColor">
                    <path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/>
                  </svg>
                </div>
              {%- endif -%}

              <div class="xalgo-testimonial__meta">
                <div class="xalgo-testimonial__author">
                  <span class="xalgo-testimonial__name">{{ block.settings.author_name }}</span>
                  {%- if block.settings.author_title != blank -%}
                    <span class="xalgo-testimonial__title">{{ block.settings.author_title }}</span>
                  {%- endif -%}
                </div>
                {%- if block.settings.platform != 'none' -%}
                  <div class="xalgo-testimonial__platform xalgo-testimonial__platform--{{ block.settings.platform }}">
                    {%- case block.settings.platform -%}
                      {%- when 'xiaohongshu' -%}
                        <span class="xalgo-testimonial__platform-icon">📕</span>
                        <span class="xalgo-testimonial__platform-name">小红书</span>
                      {%- when 'instagram' -%}
                        <span class="xalgo-testimonial__platform-icon">📷</span>
                        <span class="xalgo-testimonial__platform-name">Instagram</span>
                      {%- when 'twitter' -%}
                        <span class="xalgo-testimonial__platform-icon">🐦</span>
                        <span class="xalgo-testimonial__platform-name">Twitter</span>
                      {%- when 'weibo' -%}
                        <span class="xalgo-testimonial__platform-icon">🔴</span>
                        <span class="xalgo-testimonial__platform-name">微博</span>
                    {%- endcase -%}
                  </div>
                {%- endif -%}
              </div>
            </div>

            {%- if block.settings.rating > 0 -%}
              <div class="xalgo-testimonial__rating">
                {%- for i in (1..5) -%}
                  {%- if i <= block.settings.rating -%}
                    <span class="xalgo-testimonial__star xalgo-testimonial__star--filled">★</span>
                  {%- else -%}
                    <span class="xalgo-testimonial__star">☆</span>
                  {%- endif -%}
                {%- endfor -%}
              </div>
            {%- endif -%}

            {%- if block.settings.content != blank -%}
              <div class="xalgo-testimonial__content">
                {{ block.settings.content }}
              </div>
            {%- endif -%}

            {%- if block.settings.date != blank -%}
              <div class="xalgo-testimonial__date">
                {{ block.settings.date }}
              </div>
            {%- endif -%}
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</section>

{% stylesheet %}
  .xalgo-testimonials {
    overflow: hidden;
    background-color: #f5f6f7 !important;
  }

  .xalgo-testimonials .page-width {
    max-width: calc(var(--narrow-page-width) + 32px);
    margin-inline: auto;
    padding-inline: 16px;
  }

  @media screen and (min-width: 750px) {
    .xalgo-testimonials .page-width {
      max-width: calc(var(--narrow-page-width) + 80px);
      padding-inline: 40px;
    }
  }

  .xalgo-testimonials__header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .xalgo-testimonials__heading {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--color-foreground-heading);
    margin: 0 0 0.5rem;
  }

  .xalgo-testimonials__subheading {
    font-size: 1rem;
    color: var(--color-foreground);
    opacity: 0.7;
    margin: 0;
  }

  /* Grid Layout */
  .xalgo-testimonials__grid {
    display: grid;
    gap: 2rem;
  }

  .xalgo-testimonials__grid--grid {
    grid-template-columns: 1fr;
  }

  @media screen and (min-width: 750px) {
    .xalgo-testimonials__grid--grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media screen and (min-width: 990px) {
    .xalgo-testimonials__grid--grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .xalgo-testimonials__grid--carousel {
    grid-template-columns: 1fr;
  }

  /* Testimonial Card */
  .xalgo-testimonial {
    background: rgb(var(--color-background-rgb));
    border: 1px solid rgb(var(--color-border-rgb) / 0.1);
    border-radius: 12px;
    padding: 1.5rem;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .xalgo-testimonial:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgb(0 0 0 / 0.08);
  }

  /* Header with Avatar */
  .xalgo-testimonial__header {
    display: flex;
    gap: 1rem;
    margin-bottom: 1rem;
  }

  .xalgo-testimonial__avatar {
    flex-shrink: 0;
    width: 48px;
    height: 48px;
    border-radius: 50%;
    overflow: hidden;
    background: var(--xalgo-warm-gray, #F5F0EB);
  }

  .xalgo-testimonial__avatar-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .xalgo-testimonial__avatar--placeholder {
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-foreground);
    opacity: 0.3;
  }

  .xalgo-testimonial__avatar--placeholder svg {
    width: 28px;
    height: 28px;
  }

  /* Meta Info */
  .xalgo-testimonial__meta {
    flex: 1;
    min-width: 0;
  }

  .xalgo-testimonial__author {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .xalgo-testimonial__name {
    font-weight: 600;
    font-size: 0.9375rem;
    color: var(--color-foreground-heading);
  }

  .xalgo-testimonial__title {
    font-size: 0.8125rem;
    color: var(--color-foreground);
    opacity: 0.6;
  }

  /* Platform Badge */
  .xalgo-testimonial__platform {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    margin-top: 4px;
    padding: 2px 8px;
    border-radius: 4px;
    font-size: 0.75rem;
    background: rgb(var(--color-foreground-rgb) / 0.05);
  }

  .xalgo-testimonial__platform-icon {
    font-size: 0.875rem;
  }

  .xalgo-testimonial__platform-name {
    font-weight: 500;
  }

  /* Rating */
  .xalgo-testimonial__rating {
    margin-bottom: 0.75rem;
    color: var(--xalgo-rose, #E8A598);
    font-size: 1rem;
    letter-spacing: 2px;
  }

  .xalgo-testimonial__star--filled {
    color: var(--xalgo-rose, #E8A598);
  }

  .xalgo-testimonial__star {
    color: rgb(var(--color-foreground-rgb) / 0.2);
  }

  /* Content */
  .xalgo-testimonial__content {
    font-size: 0.9375rem;
    line-height: 1.6;
    color: var(--color-foreground);
    margin-bottom: 0.75rem;
  }

  .xalgo-testimonial__content p {
    margin: 0;
  }

  /* Date */
  .xalgo-testimonial__date {
    font-size: 0.8125rem;
    color: var(--color-foreground);
    opacity: 0.5;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Testimonials (xalgo)",
  "tag": "section",
  "class": "section-wrapper xalgo-testimonials-wrapper",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Real Women, Real Words"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Hear from our community"
    },
    {
      "type": "select",
      "id": "layout",
      "label": "Layout",
      "options": [
        { "value": "grid", "label": "Grid" },
        { "value": "carousel", "label": "Carousel" }
      ],
      "default": "grid"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 60
    }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Testimonial",
      "settings": [
        {
          "type": "image_picker",
          "id": "avatar",
          "label": "Avatar"
        },
        {
          "type": "text",
          "id": "author_name",
          "label": "Author name",
          "default": "Customer Name"
        },
        {
          "type": "text",
          "id": "author_title",
          "label": "Author title/role",
          "default": "Product Designer"
        },
        {
          "type": "select",
          "id": "platform",
          "label": "Platform",
          "options": [
            { "value": "none", "label": "None" },
            { "value": "xiaohongshu", "label": "小红书" },
            { "value": "instagram", "label": "Instagram" },
            { "value": "twitter", "label": "Twitter" },
            { "value": "weibo", "label": "微博" }
          ],
          "default": "xiaohongshu"
        },
        {
          "type": "range",
          "id": "rating",
          "label": "Star rating",
          "min": 0,
          "max": 5,
          "step": 1,
          "default": 5
        },
        {
          "type": "richtext",
          "id": "content",
          "label": "Review content",
          "default": "<p>This product changed my life. Highly recommend!</p>"
        },
        {
          "type": "text",
          "id": "date",
          "label": "Date",
          "default": "2 days ago"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Testimonials (xalgo)",
      "category": "Social",
      "blocks": [
        {
          "type": "testimonial",
          "settings": {
            "author_name": "Emma",
            "author_title": "Nurse",
            "platform": "xiaohongshu",
            "rating": 5,
            "content": "<p>The ring made me check for AFib for the first time. Now I'm not worried anymore.</p>",
            "date": "3 days ago"
          }
        },
        {
          "type": "testimonial",
          "settings": {
            "author_name": "Sarah",
            "author_title": "Creative Director",
            "platform": "instagram",
            "rating": 5,
            "content": "<p>Glasses reminded me of my meeting before I even checked my phone. Life-changing.</p>",
            "date": "1 week ago"
          }
        },
        {
          "type": "testimonial",
          "settings": {
            "author_name": "Mia",
            "author_title": "Architect",
            "platform": "xiaohongshu",
            "rating": 5,
            "content": "<p>Frame turned our Kyoto trip into an oil painting. It's the first thing guests notice.</p>",
            "date": "2 weeks ago"
          }
        }
      ]
    }
  ]
}
{% endschema %}

